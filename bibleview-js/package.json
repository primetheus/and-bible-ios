{
  "name": "bibleview-js-ios",
  "version": "1.0.0",
  "description": "AndBible iOS Vue.js frontend (forked from Android bibleview-js)",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest --root src/",
    "build-only": "vite build",
    "type-check": "vue-tsc -p tsconfig.json",
    "type-check:ci": "vue-tsc -p tsconfig.json",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "lint-fix": "eslint --fix . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "build-debug": "cross-env NODE_ENV=debug vite build --mode debug",
    "build-production": "cross-env NODE_ENV=production vite build --mode production",
    "build-development": "cross-env NODE_ENV=development vite build --mode development",
    "lint:ci": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --no-color",
    "lint:silent": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --no-color",
    "test:ci": "vitest --root src/ --run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "~6.7.2",
    "@fortawesome/free-regular-svg-icons": "~6.7.2",
    "@fortawesome/free-solid-svg-icons": "~6.7.2",
    "@fortawesome/vue-fontawesome": "~3.0.8",
    "@vue/runtime-core": "~3.5.17",
    "color": "~3.2.1",
    "dompurify": "~3.3.1",
    "lodash": "~4.17.23",
    "marked": "~17.0.1",
    "mitt": "~3.0.1",
    "sprintf-js": "~1.1.3",
    "vue": "~3.5.17",
    "vuedraggable": "~4.1.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "~1.12.0",
    "@types/color": "~3.0.6",
    "@types/js-yaml": "~4.0.9",
    "@types/jsdom": "~21.1.7",
    "@types/lodash": "~4.17.20",
    "@types/node": "~24.0.13",
    "@types/sprintf-js": "~1.1.4",
    "@typescript-eslint/eslint-plugin": "~7.18.0",
    "@typescript-eslint/parser": "~7.18.0",
    "@vitejs/plugin-vue": "~6.0.0",
    "@vue/compiler-sfc": "~3.5.17",
    "@vue/eslint-config-typescript": "~13.0.0",
    "@vue/reactivity": "~3.5.17",
    "@vue/test-utils": "~2.4.6",
    "@vue/tsconfig": "~0.7.0",
    "cross-env": "~7.0.3",
    "eslint": "~8.57.1",
    "eslint-plugin-vue": "~9.31.0",
    "js-yaml": "~4.1.1",
    "jsdom": "18.0.0",
    "npm": "~11.8.0",
    "npm-run-all": "~4.1.5",
    "sass": "~1.89.2",
    "tosource": "~2.0.0-alpha.3",
    "typescript": "~5.8.3",
    "vite": "~7.0.8",
    "vitest": "~3.2.4",
    "vue-tsc": "~3.0.1"
  },
  "note": "This is a fork of ../and-bible/app/bibleview-js/ with native-bridge.ts added for iOS WKWebView support. See CLAUDE.md for details."
}
